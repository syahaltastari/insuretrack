# Backend env (contoh). Salin ke .env dan sesuaikan.

# Database — di Docker compose, host adalah nama service "db".
DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance

# JWT signing key. WAJIB di-randomize per environment production.
# Generate: `openssl rand -hex 64`
JWT_SECRET=dev_jwt_secret_change_me_in_production

# Shared secret untuk verifikasi payment gateway webhook.
# Bandingkan dengan header `X-Webhook-Secret` (atau field body sesuai spec).
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me

# Base URL publik — dipakai untuk link di email (mis. aktivasi portal).
APP_BASE_URL=http://localhost:3000

# ---------- Storage backend ----------
# 'local' (dev, default) atau 'r2' (Cloudflare R2, prod).
# Saat STORAGE_BACKEND=r2, semua R2_* var di bawah WAJIB di-set.
STORAGE_BACKEND=local
UPLOAD_DIR=/var/uploads

# --- R2 only (ignored saat STORAGE_BACKEND=local) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=insuretrack-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev

# ---------- Email (Resend) ----------
# WAJIB di-set. Backend refuse start kalau kosong.
# Daftar di https://resend.com, verify domain untuk from address.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@insuretrack.example
# RESEND_FROM_NAME=InsureTrack

# Port
PORT=8080

# Logging filter
RUST_LOG=info,insuretrack_backend=debug
