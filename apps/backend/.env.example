# =============================================================================
# InsureTrack Backend — .env.example.
#
# Salin ke .env dan sesuaikan.
#
# Mode penggunaan:
#   - Host mode (cargo run langsung): DATABASE_URL host = localhost:5433
#     karena docker-compose.yml memetakan host 5433 → container 5432.
#   - Container mode (docker compose up backend): DATABASE_URL host = db
#     (hostname service di compose network).
# =============================================================================


# ---- Public URLs --------------------------------------------------------
# Dipakai untuk link di email (mis. aktivasi portal).
APP_BASE_URL=http://localhost:3000

# Base URL untuk aset statis (logo klien, foto testimoni). Biasanya
# menunjuk ke backend karena <img> di landing page load langsung dari
# GET /api/public/uploads/... di port backend. Default ke APP_BASE_URL.
MEDIA_BASE_URL=http://localhost:8080


# ---- Database ------------------------------------------------------------
# Host mode (default untuk dev lokal):
DATABASE_URL=postgres://insurance_admin:insurance_password@localhost:5433/digital_insurance
# Container mode (di dalam docker compose):
# DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance


# ---- Auth & secrets ------------------------------------------------------
# Production: `openssl rand -hex 64` → tempel di sini.
JWT_SECRET=dev_jwt_secret_change_me_in_production

# Bandingkan dengan X-Webhook-Secret.
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me

# ---- Auth cookies (cookie-only, no Authorization header) -----------------
# Default value cukup untuk dev. Admin & customer WAJIB pakai nama cookie
# terpisah — cookie di-scope per host (bukan per port), jadi nama yang
# sama akan collide antara localhost:3000 (portal) dan localhost:3001
# (admin), atau antara portal.X dan admin.X kalau COOKIE_DOMAIN di-set ke
# parent domain. Production: set COOKIE_DOMAIN ke parent domain (mis.
# `.insuretrack.id` untuk subdomain `portal.X`/`admin.X`/`api.X`).
ADMIN_SESSION_COOKIE_NAME=insuretrack_admin_session
ADMIN_CSRF_COOKIE_NAME=insuretrack_admin_csrf
CUSTOMER_SESSION_COOKIE_NAME=insuretrack_customer_session
CUSTOMER_CSRF_COOKIE_NAME=insuretrack_customer_csrf
COOKIE_DOMAIN=
# true di HTTPS prod, false untuk localhost HTTP dev
COOKIE_SECURE=false

# ---- CORS ----------------------------------------------------------------
# Comma-separated. WAJIB set eksplisit di production (lihat
# document/deployment/DEPLOYMENT.md). Kosongkan = fallback ke dev defaults.
CORS_ALLOWED_ORIGINS=


# ---- Storage backend -----------------------------------------------------
# 'local' (dev, default) atau 'r2' (Cloudflare R2, prod).
# Saat STORAGE_BACKEND=r2, semua R2_* var di bawah WAJIB di-set.
STORAGE_BACKEND=local

# Host mode: path relatif terhadap cwd `apps/backend/` — auto-create.
# Container mode: /var/uploads (volume mount di docker-compose).
UPLOAD_DIR=./uploads

# --- R2 only (ignored saat STORAGE_BACKEND=local) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=insuretrack-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev


# ---- Email (Resend) ------------------------------------------------------
# WAJIB di-set. Backend refuse start kalau kosong. Daftar di
# https://resend.com dan verify domain untuk from address.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@insuretrack.example
# RESEND_FROM_NAME=InsureTrack


# ---- Backend runtime -----------------------------------------------------
PORT=8080

# Default: info + debug untuk crate binary.
RUST_LOG=info,insuretrack_backend=debug
