# Admin env (contoh). Salin ke .env.local saat dev lokal.

# Base URL backend API.
#   - Dev default: `/api` (same-origin) — Next.js dev server rewrite
#     proxy ke backend di :8080. Lihat apps/portal/.env.example untuk
#     penjelasan lengkap.
NEXT_PUBLIC_API_URL=/api

# Port dev server (default 3001).
ADMIN_PORT=3001
