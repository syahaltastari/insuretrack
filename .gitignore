# =============================================================
# InsureTrack — .gitignore
# Reference: https://git-scm.com/docs/gitignore + GitHub collection
# =============================================================

# ──────────── Secrets & environment (NEVER commit) ────────────
# Backend: DATABASE_URL, JWT_SECRET, PAYMENT_WEBHOOK_SECRET, etc.
# Frontend: NEXT_PUBLIC_API_URL
.env
.env.*
!.env.example
!.env.template
# Next.js convention (also auto-ignored by next CLI)
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow committing local overrides
!.env.development
!.env.production

# ──────────── Rust / Cargo build artifacts ────────────
/target
**/target/
**/*.rs.bk
*.pdb

# Cargo.lock SHOULD be committed for binary crates (reproducible builds).
# (For libraries, it should be ignored. We're a binary, so commit it.)
# See: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# → NOT ignored (comment only).

# ──────────── Node / Next.js build artifacts ────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Testing
coverage/
.nyc_output/

# Next.js
**/.next/
/out/
next-env.d.ts
# .next/standalone is created by `output: "standalone"` (used in Docker)
# but should not be committed.

# Production
/build
/dist

# Misc
.npm
.eslintcache
.turbo

# package-lock.json SHOULD be committed (reproducible installs).
# yarn.lock / pnpm-lock.yaml — keep whichever you use; commit it.
# → NOT ignored (comment only).

# ──────────── Logs ────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Rust log
*.tracing

# ──────────── IDE / editor ────────────
.vscode/
!.vscode/extensions.json      # allow committing extension recommendations
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.vim/
.emacs.d/
.cursor/

# Claude Code local settings (per-project)
.claude/settings.local.json

# ──────────── OS junk ────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows specific
*.lnk

# ──────────── Docker / compose local volumes ────────────
# (Docker volumes are external; data persists outside the source tree.)
# No need to ignore, but in case someone uses bind-mounts:
.docker-volumes/

# Next.js standalone build output (used by Dockerfile)
**/.next/standalone/
**/.next/static/

# ──────────── Test artifacts ────────────
playwright-report/
test-results/
/coverage/

# ──────────── Build / generated ────────────
*.tsbuildinfo
# Frontend SVG/asset caches
*.cache

# ──────────── Database local dumps (in case anyone uses them) ────────────
*.db
*.sqlite
*.sqlite3
*.dump

# ──────────── Uploaded files (KTP, claim docs, e-policy PDFs) ────────────
# These are runtime artifacts — never commit user data.
/uploads/
apps/backend/uploads/

# ──────────── OS / misc ────────────
*.bak
*.swp
*.tmp
*.orig
*.rej
*.zip
*.tgz
*.gz
*.7z
*.rar

# ──────────── Temporary / scratch files ────────────
/tmp/
*.tmp
.cache/
