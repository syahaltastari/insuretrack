# Backend env (contoh). Salin ke .env dan sesuaikan.

# Database — di Docker compose, host adalah nama service "db".
DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance

# JWT signing key. WAJIB di-randomize per environment production.
# Generate: `openssl rand -hex 64`
JWT_SECRET=dev_jwt_secret_change_me_in_production

# Shared secret untuk verifikasi payment gateway webhook.
# Bandingkan dengan header `X-Webhook-Secret` (atau field body sesuai spec).
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me

# Base URL publik — dipakai untuk link di email (mis. aktivasi portal).
APP_BASE_URL=http://localhost:3000

# Direktori upload KTP & e-policy PDF.
UPLOAD_DIR=/var/uploads

# Port
PORT=8080

# Logging filter
RUST_LOG=info,insuretrack_backend=debug
