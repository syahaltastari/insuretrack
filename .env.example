# InsureTrack — secrets & config (TEMPLATE)
#
# Salin: cp .env.example .env  (JANGAN commit .env).
# Generate secret baru:
#   openssl rand -hex 64   # JWT_SECRET (128 char)
#   openssl rand -hex 32   # PAYMENT_WEBHOOK_SECRET (64 char)
#   openssl rand -hex 24   # POSTGRES_PASSWORD (48 char)


# ===== Database =====
POSTGRES_USER=insurance_admin
POSTGRES_PASSWORD=insurance_password
POSTGRES_DB=digital_insurance
# `db` = service name Postgres di Docker network. Untuk psql dari host: localhost:5433.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}


# ===== Auth & secrets (WAJIB ganti di production) =====
JWT_SECRET=dev_jwt_secret_change_me_in_production_64bytes_minimum
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me


# ===== Dokploy routing (untuk deploy VPS) =====
# Domain/IP publik yang akan di-route Traefik ke tiap service:
#   api.${DOMAIN}     → backend
#   portal.${DOMAIN}  → portal
#   admin.${DOMAIN}   → admin
# Format sslip.io: 20-189-121-230.sslip.io (replace dash dengan dot di IP).
# Format IP langsung: bisa juga, tapi sslip.io lebih fleksibel untuk test.
DOMAIN=localhost


# ===== URLs (publik) =====
# NEXT_PUBLIC_API_URL: di-bake ke client bundle saat build.
#   Lokal:    http://localhost:8080/api
#   VPS Dev:  http://api.${DOMAIN}
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# BACKEND_URL: runtime env, dipakai Next.js SSR/RSC di dalam container
# untuk fetch langsung ke service `backend` di Docker internal network.
# JANGAN set ini ke localhost (di dalam container = container itu sendiri)
# atau ke public URL (Traefik tidak jalan di internal network).
# Sudah di-hardcode di docker-compose.yml (http://backend:8080) dan Dokploy
# Secrets (lihat RUNBOOK_VPS_DEV.md §4.5). Tidak perlu di-set di .env.
# BACKEND_URL=http://backend:8080

# APP_BASE_URL: link aktivasi portal di email.
APP_BASE_URL=http://localhost:3000

# MEDIA_BASE_URL: prefix untuk file upload (KTP, PDF, claim docs).
MEDIA_BASE_URL=http://localhost:8080


# ===== Storage =====
# 'local' (default) atau 'r2' (Cloudflare R2). Saat 'r2', semua R2_* WAJIB di-set.
STORAGE_BACKEND=local
UPLOAD_DIR=/var/uploads

# --- R2 (abaikan kalau STORAGE_BACKEND=local) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=insuretrack-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev


# ===== Email (Resend) =====
# WAJIB di-set; backend refuse start kalau kosong. Verify domain di resend.com.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_FROM_NAME=InsureTrack


# ===== Optional =====
# ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
# INQUIRY_AUTO_CLOSE_DAYS=7
# RUST_LOG=info,insuretrack_backend=debug
