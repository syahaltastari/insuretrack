# =============================================================================
# InsureTrack — root .env (sumber secret + config untuk Docker stack)
#
# Salin ke .env (JANGAN commit .env, sudah di-ignore oleh .gitignore).
#
# Untuk PRODUCTION deploy via Dokploy: set var di tab **Secrets** UI Dokploy,
# bukan lewat file ini — supaya secret tidak ter-ekspos via shell history
# atau backup filesystem.
#
# Untuk generate secret baru:
#   JWT_SECRET:           openssl rand -hex 64
#   PAYMENT_WEBHOOK_SECRET: openssl rand -hex 32
#   POSTGRES_PASSWORD:    openssl rand -hex 24
# =============================================================================


# ---- Domain (Traefik routing) --------------------------------------------
# Base domain. Subdomain otomatis:
#   api.${DOMAIN}     → backend (Rust API)
#   portal.${DOMAIN}  → portal Next.js (customer surface)
#   admin.${DOMAIN}   → admin Next.js (backoffice)
#
# Contoh:
#   DOMAIN=insuretrack.example.com  →  api.insuretrack.example.com, dst
#   DOMAIN=20.189.121.230.sslip.io  →  api.20-189-121-230.sslip.io (dev only)
DOMAIN=insuretrack.example.com

# Email untuk Let's Encrypt registration. WAJIB di-set di production agar
# LE kirim notifikasi expiry. Tidak wajib untuk sslip.io (LE gagal issue
# cert untuk *.sslip.io — lihat document/DEPLOYMENT.md §4.2).
# ACME_EMAIL=ops@insuretrack.example.com


# ---- Replicas & resource sizing ------------------------------------------
# Replicas per app service (backend, portal, admin). Default 2 untuk
# HA + zero-downtime deploy. Set 1 untuk local dev (hemat memory).
# REPLICAS=2


# ---- Network (host ports) -----------------------------------------------
# Port host untuk local dev only. Dokploy mode: abaikan, Traefik handle
# routing via labels. db di-bind ke 127.0.0.1 saja (tidak public).
# BACKEND_PORT=8080
# PORTAL_PORT=3000
# ADMIN_PORT=3001
# POSTGRES_PORT=5433


# ---- Public URLs --------------------------------------------------------
# NEXT_PUBLIC_API_URL: di-bake ke Next.js client bundle saat build.
# Browser pakai URL ini untuk fetch API. HARUS URL yang bisa diakses
# dari browser user (public hostname, bukan `backend:8080`).
NEXT_PUBLIC_API_URL=https://api.${DOMAIN}

# APP_BASE_URL: dipakai backend untuk generate link di email (portal
# activation, e-policy download, dll). Public hostname portal.
APP_BASE_URL=https://portal.${DOMAIN}

# MEDIA_BASE_URL: prefix untuk serve uploaded file (KTP, claim docs,
# e-policy PDF) yang dilayani backend. Kalau STORAGE_BACKEND=r2,
# set ke R2 public URL; kalau local, set ke API URL.
MEDIA_BASE_URL=https://api.${DOMAIN}


# ---- Database ------------------------------------------------------------
# Username, password, dan nama database. WAJIB diganti di production
# dengan secret yang digenerate via `openssl rand -hex 24` (lihat header).
POSTGRES_USER=insurance_admin
POSTGRES_PASSWORD=insurance_password
POSTGRES_DB=digital_insurance

# URL backend connect ke DB. `db` = hostname service PostgreSQL di
# docker-compose network (otomatis resolve via Docker DNS).
# Untuk local dev (psql dari host), `db` tidak resolve — pakai port
# mapping `127.0.0.1:5433` di docker-compose.
# `?sslmode=require` HANYA untuk managed Postgres (Neon, RDS, Azure DB).
# Local docker-compose Postgres tanpa TLS — JANGAN pakai sslmode=require
# (kalau tidak ada TLS di server, query akan fail).
DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance


# ---- Auth & secrets ------------------------------------------------------
# Production: `openssl rand -hex 64` → tempel di sini.
JWT_SECRET=dev_jwt_secret_change_me_in_production_64bytes_minimum

# Bandingkan dengan X-Webhook-Secret (atau field body sesuai spec).
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me


# ---- Storage backend -----------------------------------------------------
# 'local' (dev, default) atau 'r2' (Cloudflare R2, prod).
# Saat STORAGE_BACKEND=r2, semua R2_* var di bawah WAJIB di-set atau
# backend refuse start (hard-fail). Lihat document/R2_SETUP.md.
STORAGE_BACKEND=local
UPLOAD_DIR=/var/uploads

# --- R2 only (ignored saat STORAGE_BACKEND=local) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=insuretrack-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev


# ---- Email (Resend) ------------------------------------------------------
# WAJIB di-set. Backend refuse start kalau kosong. Daftar di
# https://resend.com dan verify domain untuk from address.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@insuretrack.example
# RESEND_FROM_NAME=InsureTrack

# Email tujuan untuk notifikasi inbound ke tim (inquiry baru, customer reply).
# Optional — kalau kosong, fallback ke first admin_users.email dari DB.
# ADMIN_NOTIFICATION_EMAIL=admin@insuretrack.example

# Auto-close inquiry (ANSWERED → CLOSED) kalau customer tidak balas dalam
# N hari. Default 7. Set 0 untuk disable auto-close.
# INQUIRY_AUTO_CLOSE_DAYS=7


# ---- DB Backup (db-backup service) --------------------------------------
# Cron schedule untuk backup otomatis. Default @daily (02:30 server time,
# di luar jam sibuk). Format: @daily, @weekly, @hourly, atau cron expr.
BACKUP_CRON_SCHEDULE=@daily

# Retention policy — file backup lama dihapus otomatis.
# Default: 7 harian + 4 mingguan + 6 bulanan + 1 tahunan = total ~80 file.
# Untuk compliance (UU PDP), JANGAN kurangi BACKUP_KEEP_YEARS di bawah 1.
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
BACKUP_KEEP_YEARS=1

# Offsite backup target (Phase 2 — opsional). Kalau di-set, db-backup akan
# rclone ke remote setelah backup lokal selesai. Format: rclone remote
# path, mis. "azureblob:insuretrack-backups/db".
# BACKUP_OFFSITE_TARGET=


# ---- Backend runtime -----------------------------------------------------
PORT=8080

# Default: info + debug untuk crate binary.
RUST_LOG=info,insuretrack_backend=debug
