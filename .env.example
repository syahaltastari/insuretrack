# InsureTrack — root .env (sumber tunggal secret untuk Docker stack).
# Salin ke `.env` (jangan commit .env, sudah di-ignore oleh .gitignore).
# Generate secret baru via `openssl rand -hex 64` di environment production.

# ---------- Host ports (opsional, default di docker-compose) ----------
# BACKEND_PORT=8080
# FRONTEND_PORT=3000

# ---------- Frontend public URL (di-bake ke Next.js saat build) ----------
# Dipakai oleh frontend untuk call backend API. Saat pakai Docker compose
# dengan custom BACKEND_PORT, set ulang agar match.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ---------- PostgreSQL credentials ----------
# Username, password, dan nama database. Password WAJIB diganti di production.
POSTGRES_USER=insurance_admin
POSTGRES_PASSWORD=insurance_password
POSTGRES_DB=digital_insurance

# ---------- Backend connection (di-resolve di dalam Docker network) ----------
# `db` adalah hostname service PostgreSQL di docker-compose.
DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance

# ---------- JWT signing key (WAJIB di-randomize per environment) ----------
# Production: `openssl rand -hex 64` → tempel di sini.
JWT_SECRET=dev_jwt_secret_change_me_in_production

# ---------- Payment gateway webhook secret (WAJIB di-randomize) ----------
# Bandingkan dengan header `X-Webhook-Secret` (atau field body sesuai spec).
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me

# ---------- Backend port ----------
PORT=8080

# ---------- Logging filter ----------
# Default: info + debug untuk crate binary.
RUST_LOG=info,insuretrack_backend=debug
