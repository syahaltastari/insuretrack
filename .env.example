# =============================================================================
# InsureTrack — root .env (sumber secret untuk Docker stack).
#
# Salin ke .env (jangan commit .env, sudah di-ignore oleh .gitignore).
# Generate secret baru via `openssl rand -hex 64` di environment production.
# =============================================================================


# ---- Network (host ports) -----------------------------------------------
# Port host yang dipublish oleh docker-compose. Override kalau perlu.
# BACKEND_PORT=8080
# PORTAL_PORT=3000
# ADMIN_PORT=3001


# ---- Public URLs --------------------------------------------------------
# Di-bake ke Next.js saat build (NEXT_PUBLIC_*) atau dipakai backend saat
# generate link email. Saat pakai custom BACKEND_PORT, sesuaikan manual.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
APP_BASE_URL=http://localhost:3000
MEDIA_BASE_URL=http://localhost:8080


# ---- Database ------------------------------------------------------------
# Username, password, dan nama database. WAJIB diganti di production.
POSTGRES_USER=insurance_admin
POSTGRES_PASSWORD=insurance_password
POSTGRES_DB=digital_insurance

# URL backend connect ke DB. `db` = hostname service PostgreSQL di
# docker-compose network (otomatis resolve).
DATABASE_URL=postgres://insurance_admin:insurance_password@db:5432/digital_insurance


# ---- Auth & secrets ------------------------------------------------------
# Production: `openssl rand -hex 64` → tempel di sini.
JWT_SECRET=dev_jwt_secret_change_me_in_production

# Bandingkan dengan X-Webhook-Secret (atau field body sesuai spec).
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me


# ---- Storage backend -----------------------------------------------------
# 'local' (dev, default) atau 'r2' (Cloudflare R2, prod).
# Saat STORAGE_BACKEND=r2, semua R2_* var di bawah WAJIB di-set atau
# backend refuse start (hard-fail).
STORAGE_BACKEND=local
UPLOAD_DIR=/var/uploads

# --- R2 only (ignored saat STORAGE_BACKEND=local) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=insuretrack-uploads
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev


# ---- Email (Resend) ------------------------------------------------------
# WAJIB di-set. Backend refuse start kalau kosong. Daftar di
# https://resend.com dan verify domain untuk from address.
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=noreply@insuretrack.example
# RESEND_FROM_NAME=InsureTrack

# Email tujuan untuk notifikasi inbound ke tim (inquiry baru, customer reply).
# Optional — kalau kosong, fallback ke first admin_users.email dari DB.
# ADMIN_NOTIFICATION_EMAIL=admin@insuretrack.example

# Auto-close inquiry (ANSWERED → CLOSED) kalau customer tidak balas dalam
# N hari. Default 7. Set 0 untuk disable auto-close.
# INQUIRY_AUTO_CLOSE_DAYS=7


# ---- Backend runtime -----------------------------------------------------
PORT=8080

# Default: info + debug untuk crate binary.
RUST_LOG=info,insuretrack_backend=debug
