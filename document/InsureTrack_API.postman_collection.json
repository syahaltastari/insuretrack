{
  "info": {
    "name": "InsureTrack API",
    "description": "Complete API collection for the InsureTrack digital insurance platform.\n\n**Import instructions:**\n1. Open Postman → File → Import → select this file.\n2. After import, edit the `base_url` variable to point to your backend (default `http://localhost:8080/api`).\n3. Hit **Customer → Login** to populate `customer_token`, then **Admin → Login** for `admin_token`. Tokens auto-save via the test scripts.\n\n**Folder layout:**\n- `01 — Public` (no auth): products, registration, payment webhook, marketing content.\n- `02 — Customer` (Bearer): activate, login, profile, policies, invoices, claims, inquiries.\n- `03 — Admin` (Bearer): dashboard, registrations, invoices, policies, claims, inquiries, marketing CRUD, email/audit logs.\n- `04 — Webhook`: payment webhook (X-Webhook-Secret header).\n\n**Variables:**\n- `base_url` — backend base (e.g., `http://localhost:8080/api`)\n- `customer_token` — auto-populated by Customer/Login\n- `admin_token` — auto-populated by Admin/Login\n- `webhook_secret` — must match `PAYMENT_WEBHOOK_SECRET` in backend `.env`\n- `customer_id` / `policy_id` / `invoice_id` / etc. — sample UUIDs to override in requests that need path params",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "customer_token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "webhook_secret", "value": "dev_webhook_secret_change_me", "type": "string" },
    { "key": "customer_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "registration_no", "value": "REG-202606-000001", "type": "string" },
    { "key": "policy_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "invoice_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "invoice_no", "value": "INV-202606-000001", "type": "string" },
    { "key": "claim_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "inquiry_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "client_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "testimonial_id", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "activation_token", "value": "", "type": "string" },
    { "key": "reset_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "01 — Public",
      "description": "Endpoints that do not require authentication. Used by the public landing page and external payment gateway.",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/products",
              "host": ["{{base_url}}"],
              "path": ["public", "products"]
            }
          }
        },
        {
          "name": "Register Customer (Account Creation)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123\",\n  \"mobile_number\": \"081234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/public/customers",
              "host": ["{{base_url}}"],
              "path": ["public", "customers"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.customer_id) { pm.collectionVariables.set('customer_id', json.customer_id); }",
                  "// Optional: extract activation URL token for later use in Customer/Activate",
                  "if (json.activation_url) {",
                  "  const m = json.activation_url.match(/token=([^&]+)/);",
                  "  if (m) { pm.collectionVariables.set('activation_token', m[1]); }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Registration Status by Reg No",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/registrations/:reg_no",
              "host": ["{{base_url}}"],
              "path": ["public", "registrations", ":reg_no"],
              "variable": [
                { "key": "reg_no", "value": "{{registration_no}}", "type": "string" }
              ]
            }
          }
        },
        {
          "name": "List Public Clients (Landing Page)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/clients",
              "host": ["{{base_url}}"],
              "path": ["public", "clients"]
            }
          }
        },
        {
          "name": "List Public Testimonials (Landing Page)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/testimonials",
              "host": ["{{base_url}}"],
              "path": ["public", "testimonials"]
            }
          }
        },
        {
          "name": "Serve Upload (Static File)",
          "description": "Serves uploaded files (KTP, client logos, testimonial photos, e-policy PDF, invoice PDF). Path is the storage key (e.g., `policies/<uuid>.pdf`).",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/public/uploads/policies/example.pdf",
              "host": ["{{base_url}}"],
              "path": ["public", "uploads", "policies", "example.pdf"]
            }
          }
        }
      ]
    },
    {
