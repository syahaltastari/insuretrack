    {
      "name": "04 — Webhook",
      "description": "Server-to-server webhook. Auth via `X-Webhook-Secret` header, not Bearer token.",
      "item": [
        {
          "name": "Payment Webhook (Mark Invoice as PAID)",
          "description": "Called by the payment gateway when an invoice is paid. Triggers: invoice → PAID, registration → ISSUED, policy creation, e-policy PDF render, 2 emails (PaymentSuccess + EPolicyDelivery). **Idempotent**: replaying with same `invoice_no` returns success without re-creating the policy or re-sending emails.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Webhook-Secret", "value": "{{webhook_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice_no\": \"{{invoice_no}}\",\n  \"payment_status\": \"PAID\",\n  \"payment_date\": \"2026-06-07\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/public/payment/webhook",
              "host": ["{{base_url}}"],
              "path": ["public", "payment", "webhook"]
            }
          }
        }
      ]
    }
