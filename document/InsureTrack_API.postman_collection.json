              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/customer/activate",
              "host": ["{{base_url}}"],
              "path": ["customer", "activate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('customer_token', json.token); }"
                ]
              }
            }
          ]
        },
