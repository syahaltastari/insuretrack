# Monorepo-wide .npmrc. Overrides per-package .npmrc (e.g. frontend/.npmrc).
#
# `node-linker=hoisted` forces pnpm to install deps in a flat node_modules
# (like npm). `public-hoist-pattern[]=*` + `public-hoist-pattern[]=@*/*`
# memaksa SEMUA package (termasuk yang punya peer-dep conflict) di-hoist
# sebagai real directory, bukan symlink balik ke .pnpm/. Tanpa baris ini,
# pnpm tetap membuat symlink `pkg -> ../../../node_modules/.pnpm/...` di
# root node_modules, dan symlink itu dangling ketika di-COPY ke image
# runtime yang beda working dir (mis. /app/node_modules).
node-linker=hoisted
public-hoist-pattern[]=*
public-hoist-pattern[]=@*/*
# Allow build scripts (sharp needs to run install scripts to build binaries).
# We accept the supply-chain risk here for the convenience of automated builds.
auto-install-peers=true
strict-peer-dependencies=false
